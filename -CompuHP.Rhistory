# ============================
# Variables demográficas sugeridas
# ============================
sexo_var <- if (!is.null(E)) col_first_existing(E, c("NPCEP5")) else NULL
edad_var <- if (!is.null(E)) col_first_existing(E, c("NPCEP4")) else NULL
if (!is.null(E) && !is.null(sexo_var)) {
tabla_sexo <- E %>%
mutate(sexo = as.character(.data[[sexo_var]])) %>%
count(sexo, name = "personas") %>%
mutate(pct = personas / sum(personas))
datatable(tabla_sexo,
rownames = FALSE,
options = list(pageLength = 10),
caption = "Distribución de personas por sexo")
}
if (!is.null(E) && !is.null(edad_var)) {
perfil_edad <- E %>%
mutate(edad = suppressWarnings(as.numeric(.data[[edad_var]]))) %>%
filter(!is.na(edad), edad >= 0, edad <= 110)
tabla_edad <- perfil_edad %>%
mutate(grupo_edad = floor(edad / 5) * 5) %>%
count(grupo_edad, name = "frecuencia")
g_edad <- ggplot(
tabla_edad,
aes(
x = grupo_edad,
y = frecuencia,
text = paste0(
"Grupo de edad: ", grupo_edad, "-", grupo_edad + 4,
"<br>Frecuencia: ", frecuencia
)
)
) +
geom_col() +
labs(
title = "Distribución de edad de la población encuestada",
x = "Edad",
y = "Frecuencia"
) +
theme_minimal()
plotly::ggplotly(g_edad, tooltip = "text")
}
res_comp <- diagnostico_completitud_capitulos(dfs)
res_comp$resumen_general %>%
mutate(
porcentaje = encuestas_completas / encuestas_totales
) %>%
gt() %>%
cols_label(
encuestas_totales = "Encuestas totales",
encuestas_completas = "Encuestas completas",
porcentaje = "% completas"
) %>%
fmt_number(
columns = c(encuestas_totales, encuestas_completas),
use_seps = TRUE
) %>%
fmt_percent(
porcentaje,
decimals = 2
) %>%
tab_header(
title = "Resumen general del operativo"
) %>%
cols_align("center")
res_comp$resumen_capitulo %>%
arrange(desc(hogares_faltantes)) %>%
gt() %>%
cols_label(
capitulo = "Capítulo",
hogares_requeridos = "Requeridos",
hogares_ok = "Completos",
hogares_faltantes = "Faltantes",
pct_ok = "% completos",
pct_faltantes = "% faltantes"
) %>%
fmt_number(
columns = c(hogares_requeridos, hogares_ok, hogares_faltantes),
decimals = 0,
use_seps = TRUE
) %>%
fmt_number(
columns = c(pct_ok, pct_faltantes),
decimals = 2,
suffixing = FALSE
) %>%
text_transform(
locations = cells_body(columns = c(pct_ok, pct_faltantes)),
fn = function(x) paste0(x, "%")
) %>%
cols_align(
align = "center",
columns = c(hogares_requeridos, hogares_ok, hogares_faltantes, pct_ok, pct_faltantes)
) %>%
tab_header(
title = "Capítulos ordenados por hogares faltantes"
) %>%
opt_row_striping()
glimpse(res_comp$encuestas_incompletas)
res_comp$encuestas_incompletas %>%
gt() %>%
fmt_number(
columns = where(is.numeric),
decimals = 0,
use_seps = TRUE
) %>%
cols_align(
align = "center",
columns = where(is.numeric)
) %>%
tab_header(
title = "Listado de encuestas incompletas"
) %>%
opt_row_striping()
