dplyr::filter(encuesta_efectiva_campo & !encuesta_completa_campo) %>%
dplyr::count(
todos_hogares_completos,
todas_personas_completas
) %>%
dplyr::mutate(
pct = n / sum(n),
todos_hogares_completos = dplyr::if_else(
todos_hogares_completos, "Sí", "No"
),
todas_personas_completas = dplyr::if_else(
todas_personas_completas, "Sí", "No"
)
) %>%
dplyr::arrange(dplyr::desc(n))
labels_diag_incomp <- c(
todos_hogares_completos = "Hogares completos",
todas_personas_completas = "Personas completas",
n = "Encuestas",
pct = "Porcentaje"
)
tabla_gt(
tabla_diag_incomp,
titulo = "Diagnóstico de incompletitud: hogar vs persona",
labels = labels_diag_incomp
)
