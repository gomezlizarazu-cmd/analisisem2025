# 1. Coordenada representativa por segmento
coords_segmento <- A %>%
dplyr::filter(
!is.na(SEGMENTO),
!is.na(GEOVISORX),
!is.na(GEOVISORY)
) %>%
dplyr::mutate(
lon = as.numeric(GEOVISORX),
lat = as.numeric(GEOVISORY)
) %>%
dplyr::filter(
lon > -79.5, lon < -66.5,
lat > -4.5,  lat < 13.5
) %>%
dplyr::group_by(SEGMENTO) %>%
dplyr::summarise(
lon = mean(lon, na.rm = TRUE),
lat = mean(lat, na.rm = TRUE),
municipio = dplyr::first(NomMunicipio),
localidad = dplyr::first(LOCALIDAD),
.groups = "drop"
)
# 2. Unir con el resumen de caída
mapa_caida <- res_fino$resumen_segmento %>%
dplyr::inner_join(coords_segmento, by = "SEGMENTO") %>%
dplyr::filter(
!is.na(caida),
!is.na(lon),
!is.na(lat)
)
# 3. Paleta de colores
pal <- leaflet::colorNumeric(
palette = "YlOrRd",
domain = mapa_caida$caida,
na.color = "transparent"
)
# 4. Crear mapa
leaflet(
mapa_caida,
options = leafletOptions(preferCanvas = TRUE)
) %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addCircleMarkers(
lng = ~lon,
lat = ~lat,
radius = ~pmax(4, scales::rescale(caida, to = c(4, 10))),
stroke = FALSE,
fillOpacity = 0.75,
color = ~pal(caida),
popup = ~paste0(
"<b>Segmento:</b> ", SEGMENTO,
"<br><b>Municipio:</b> ", municipio,
"<br><b>Localidad:</b> ", localidad,
"<br><b>Hogares totales:</b> ", hogares_totales,
"<br><b>Completos:</b> ", hogares_completos,
"<br><b>Incompletos:</b> ", hogares_incompletos,
"<br><b>Cobertura:</b> ", scales::percent(cobertura),
"<br><b>Caída:</b> ", scales::percent(caida)
)
) %>%
addLegend(
pal = pal,
values = ~caida,
title = "Caída"
) %>%
fitBounds(
lng1 = min(mapa_caida$lon, na.rm = TRUE),
lat1 = min(mapa_caida$lat, na.rm = TRUE),
lng2 = max(mapa_caida$lon, na.rm = TRUE),
lat2 = max(mapa_caida$lat, na.rm = TRUE)
) %>%
htmlwidgets::onRender("
function(el, x) {
setTimeout(function() {
this.invalidateSize();
}.bind(this), 300);
}
")
